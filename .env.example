# ════════════════════════════════════════════════════════════════════════
# docker compose 环境变量 —— 复制为 .env 后按需填写:  cp .env.example .env
# 仅根目录 docker-compose.yml 读取;各服务自身的 .env 在 packages/<service>/ 下。
# ⚠ .env 已被 .gitignore 忽略,严禁提交;本文件只放占位值,不要写真实密钥。
# ════════════════════════════════════════════════════════════════════════

# ── 数据库 ────────────────────────────────────────────────────────────────
# Postgres 超级用户密码(boss_gateway / smart_job 两库共用)。公网部署务必改强口令。
POSTGRES_PASSWORD=password

# ── api-gateway ──────────────────────────────────────────────────────────
# 管理后台密码。留空 = 本地开发不校验;公网部署务必设强口令。
ADMIN_PASSWORD=

# ── agent-gateway / LLM ──────────────────────────────────────────────────
# OpenRouter API key(Agent 对话用)。留空则 Agent 对话功能不可用。
OPENROUTER_API_KEY=
# LLM 兼容端点 base url(走 OpenRouter 的 Anthropic 兼容端点时如下)
ANTHROPIC_BASE_URL=https://openrouter.ai/api
# Agent 模型(OpenRouter id,形如 provider/model)。留空走 compose 默认。
AGENT_MODEL=z-ai/glm-5-turbo

# ── Agent 运行参数(可选,留空走代码默认值)────────────────────────────────
MAX_SESSIONS=20
MAX_MESSAGES=60
MAX_TOKENS=8096
WORKER_COUNT=1
SESSION_IDLE_TTL=1800
TOOL_CALL_TIMEOUT=60
TURN_TIMEOUT=600
ENABLE_THINKING=true
THINKING_BUDGET_TOKENS=8000
AGENT_LOG_DIR=logs
AGENT_LOG_LEVEL=INFO
AGENT_DEBUG_MODE=false
# 内部简历解析 API;留空 = 关闭该功能
INTERNAL_RESUME_API_URL=

# ── 讯飞语音(可选 — 三个密钥留空即关闭语音输入/播报)──────────────────────
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
XFYUN_ASR_URL=wss://iat-api.xfyun.cn/v2/iat
XFYUN_TTS_URL=wss://tts-api.xfyun.cn/v2/tts
