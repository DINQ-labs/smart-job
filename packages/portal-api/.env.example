# ── 数据库 ─────────────────────────────────────────────────────────────────
# 共享 smart-job 现有 Postgres，使用 identity schema；启动时自动 CREATE SCHEMA + CREATE TABLE IF NOT EXISTS
DATABASE_URL="postgresql://postgres:CHANGE_ME@127.0.0.1:5432/smart_job"
DB_SCHEMA="identity"

# 连接池
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── HTTP ─────────────────────────────────────────────────────────────────
PORT=8771
APP_ENV="development"    # development | production
# CORS 允许的来源；逗号分隔。开发期默认放开所有 chrome-extension:// 和 http://localhost:*
# 生产期推荐显式列出：https://job.joyhouse.chat,chrome-extension://abcd1234...
CORS_ORIGINS=""

# ── JWT / JWKS ───────────────────────────────────────────────────────────
# 私钥 PEM 路径。文件不存在时启动自动生成 RSA-2048 并落盘。
JWT_PRIVATE_KEY_PATH="./keys/jwt-private.pem"
# 留空时从公钥 SHA-256 派生 kid（前 12 chars）。轮换密钥时改这里。
JWT_KEY_ID=""
JWT_ISSUER="https://job.joyhouse.chat"
JWT_AUDIENCE="job-portal"
ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=30

# ── Resend 邮件 ───────────────────────────────────────────────────────────
# 留空：开发模式把验证码打到 stdout（[dev:verification] ...）
# 配置：登 https://resend.com，verify domain（job.joyhouse.chat），创建 API key
RESEND_API_KEY=""
# 发件人必须用 Resend 已验证域；开发期可用 onboarding@resend.dev
RESEND_FROM="DingQ <noreply@job.joyhouse.chat>"

# ── 业务参数（可选覆盖默认值，否则用代码里的常量）────────────────────────────
# CODE_TTL_MINUTES=10
# CODE_MAX_ATTEMPTS=5
# CODE_RESEND_COOLDOWN_SECONDS=60
