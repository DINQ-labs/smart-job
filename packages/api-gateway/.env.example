# ── Boss API Gateway 配置示例 ──────────────────────────────────────────────
# 复制为 .env 并按实际情况修改。

BOSS_GATEWAY_PORT=8767
# Public base URL exposed to clients (used in login_url returned by boss_login)
# Default: http://127.0.0.1:{BOSS_GATEWAY_PORT}
# GATEWAY_PUBLIC_URL=http://your-server-ip:8767
# 管理后台鉴权开关 + 首个管理员账号 admin 的初始口令(之后在后台改密 / 加账号)。
# 留空 = 本地开发不校验;公网部署务必设强口令。
ADMIN_PASSWORD=

# ── 扩展 WebSocket 握手鉴权 ────────────────────────────────────────────────
# 三种模式:
#   1. 都留空                  → 内网 / 开发:不校验,任何客户端可连(仅打 warning)。
#   2. 设 EXT_TOKEN            → 静态共享密钥:扩展握手须带同一 token(或合法
#                                portal JWT)。整支扩展车队共用一个值。
#   3. EXT_AUTH_REQUIRED=true 且不设 EXT_TOKEN → 仅接受合法 portal JWT。
# 公网部署务必走模式 2 或 3。
EXT_TOKEN=
EXT_AUTH_REQUIRED=
# portal JWT 验签参数(用 portal access token 鉴权时才需要;留空 = 用内置默认值)。
# docker 栈内 portal 是 portal-api 容器,应改为:
#   PORTAL_JWKS_URL=http://portal-api:8771/.well-known/jwks.json
PORTAL_JWKS_URL=
JWT_ISSUER=
JWT_AUDIENCE=

# 数据库后端: sqlite(零配置默认) | postgres | both
DB_BACKEND=postgres
DB_POSTGRES_URL=postgresql://postgres:password@localhost:5432/boss_gateway
# SQLite 文件路径(DB_BACKEND=sqlite / both 时生效)
# DB_PATH=./boss_gateway.db

BOSS_GATEWAY_URL=http://127.0.0.1:8767
# BOSS_SESSION_ID=

# 代理 IP 池（逗号分隔，留空直连）
# 支持: http://ip:port, https://ip:port, socks5://ip:port, socks4://ip:port
PROXY_POOL=
PROXY_ASSIGN_STRATEGY=round_robin

# ─── Billing / Stripe（详见 BILLING_SETUP.md） ─────────────────────────────
# 从 Stripe Dashboard → Developers → API keys 复制
STRIPE_SECRET_KEY=
# 从 Stripe Dashboard → Developers → Webhooks 复制（每个 endpoint 一个）
STRIPE_WEBHOOK_SECRET=
# 三个 Price ID（在 Stripe Dashboard → Products 创建后获得）
STRIPE_PRICE_JOBSEEKER_PRO=
STRIPE_PRICE_RECRUITER_PRO=
STRIPE_PRICE_CREDIT_100=
# Checkout success / cancel 回跳 URL（前端处理 ?session_id=...）
BILLING_SUCCESS_URL=https://job.joyhouse.chat/billing/success
BILLING_CANCEL_URL=https://job.joyhouse.chat/billing/cancel
# Customer Portal 返回 URL
BILLING_PORTAL_RETURN_URL=https://job.joyhouse.chat/billing
