# ── job-agent-gateway 配置示例 ──────────────────────────────────────────────

# 二选一:OpenRouter(优先)或 Anthropic 直连
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# LLM 兼容端点 base_url。走 OpenRouter 的 Anthropic 兼容端点时设:
ANTHROPIC_BASE_URL=https://openrouter.ai/api
# 直连 OpenRouter 原生端点时改用:
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# 模型(OpenRouter 格式:provider/model)
# AGENT_MODEL=anthropic/claude-opus-4-6
# AGENT_MODEL=openai/gpt-4o

# 服务端口
AGENT_GW_PORT=8769

# 内部依赖
BOSS_API_GATEWAY_URL=http://127.0.0.1:8767
JOB_PORTAL_API_URL=http://127.0.0.1:8771
# 内部简历解析 API(留空 = 关闭简历解析)
INTERNAL_RESUME_API_URL=
# Postgres(共用 boss_gateway db / 或独立 db)
DB_POSTGRES_URL=postgresql://postgres:CHANGE_ME@localhost:5432/boss_gateway

# ── SSE / 写路径鉴权 ───────────────────────────────────────────────────────
# AGENT_AUTH_REQUIRED=true(生产 / 公网):/agent/sse 等路径必须带合法
#   Authorization: Bearer <portal access token>,user_id 一律取 JWT sub。
# 留空(内网 / 开发):带合法 Bearer 就用其 sub,否则回退 query 里的 user_id。
AGENT_AUTH_REQUIRED=
# portal JWT 验签参数(留空 = 用内置默认值)。docker 栈内应指向 portal-api 容器:
#   PORTAL_JWKS_URL=http://portal-api:8771/.well-known/jwks.json
PORTAL_JWKS_URL=
JWT_ISSUER=
JWT_AUDIENCE=

# Billing 跨服务调用 api-gw
BILLING_ENFORCE=0

# Anthropic / OpenRouter 限流
MAX_SESSIONS=100
MAX_TOKENS=8000
TOOL_CALL_TIMEOUT=30
TURN_TIMEOUT=180
CONCURRENT_TURNS=10
SESSION_IDLE_TTL=1800
MAX_MESSAGES=200
WORKER_COUNT=2
ENABLE_THINKING=0
THINKING_BUDGET_TOKENS=2000

# 日志
AGENT_LOG_DIR=logs
AGENT_LOG_LEVEL=INFO
AGENT_DEBUG_MODE=0

# Redis(可选,任务调度)
REDIS_URL=redis://127.0.0.1:6379/0

# 讯飞语音(可选 — 留空关闭语音)
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
XFYUN_ASR_URL=wss://iat-api.xfyun.cn/v2/iat
XFYUN_TTS_URL=wss://tts-api.xfyun.cn/v2/tts
